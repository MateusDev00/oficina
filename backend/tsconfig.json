{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "moduleResolution": "node",
    "baseUrl": "src",
    "paths": {
      "@configuracao/*": ["configuracao/*"],
      "@intermediarios/*": ["intermediarios/*"],
      "@modulos/*": ["modulos/*"],
      "@nucleo/*": ["src/nucleo/*"],
      "@tipos/*": ["src/tipos/*"]
    }
  },
  "include": ["src/**/*", "src/tipos", "src/nucleo", "configuracao", "src/tipos", "modulos"],
  "exclude": ["node_modules", "dist"]
}